<h1>Pacientes</h1>

<a href="/pacientes/cadastrar">Novo Paciente</a>

<table border="1">
    <tr>
        <th>Nome</th>
        <th>CPF</th>
        <th>Telefone</th>
        <th>Email</th>
        <th>Nascimento</th>
        <th>Ações</th>
    </tr>

    {{#each pacientes}}
    <tr>
        <td>{{this.nome}}</td>
        <td>{{this.cpf}}</td>
        <td>{{this.telefone}}</td>
        <td>{{this.email}}</td>
        <td>{{this.dataNascimento}}</td>
        <td>
            <a href="/pacientes/editar/{{this.id}}">Editar</a>
            <a href="/pacientes/excluir/{{this.id}}">Excluir</a>
        </td>
    </tr>
    {{/each}}

</table>
